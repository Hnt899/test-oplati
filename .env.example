# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.onrender.com
# Public URL of this site (Stripe success/cancel redirects). On Render use your HTTPS URL, e.g.:
# SITE_URL=https://test-oplati.onrender.com
SITE_URL=http://localhost:8000

# Database (omit or use sqlite URL for local SQLite)
# DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Stripe — RUB account (pk_/sk_test_… from Stripe Dashboard)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Stripe — EUR account (separate Stripe account or restricted key scope)
STRIPE_PUBLISHABLE_KEY_EUR=
STRIPE_SECRET_KEY_EUR=
